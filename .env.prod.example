# Copier en `.env` sur le serveur de prod, à côté de docker-compose.prod.yml.
# Ce fichier (.env) ne doit JAMAIS être commité.

# --- Strava OAuth ---
# Côté Strava, mettre l'Authorization Callback Domain = votre domaine de prod
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_CALLBACK_URL=https://votre-domaine.fr/auth/callback

# --- Session ---
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- URLs ---
# Front et back sont en même origine (nginx proxy), donc l'URL du domaine public
FRONTEND_URL=https://votre-domaine.fr

# --- Déploiement (variables lues par docker-compose) ---
# Tag d'image à déployer (latest, ou un SHA de commit précis pour pinner/rollback)
IMAGE_TAG=latest
# Port HTTP exposé par le serveur
HTTP_PORT=80
