# Copier ce fichier en `.env` et renseigner les valeurs.
# `.env` ne doit JAMAIS être commité (il est dans .gitignore).

# --- Strava OAuth (https://www.strava.com/settings/api) ---
# Authorization Callback Domain à mettre côté Strava : localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_CALLBACK_URL=http://localhost:3001/auth/callback

# --- Session ---
# Générer un secret : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Serveur ---
PORT=3001
# URL du front (cible des redirections post-OAuth + origine CORS). Dev Vite = :3000
FRONTEND_URL=http://localhost:3000

# Mettre à "production" en déploiement (active cookies secure + trust proxy)
# NODE_ENV=production
